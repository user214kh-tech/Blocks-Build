function handleUploadFile(file){
  if(!file) return;
  const okTypes = ['image/png','image/jpeg','image/webp'];
  if(!okTypes.includes(file.type)){
    setUploadStatus('Unsupported file type — use PNG, JPG, JPEG, or WEBP.', false);
    return;
  }
  const reader = new FileReader();
  reader.onload = (e) => {
    const img = new Image();
    img.onload = () => {
      uploadedImage = img;
      setUploadStatus(`Converting "${file.name}" (${img.width}×${img.height} → ${fSize.value || '?'}×${fSize.value || '?'})…`, false);
      convertUploadedImage();
    };
    img.onerror = () => setUploadStatus('Could not read that image file.', false);
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

