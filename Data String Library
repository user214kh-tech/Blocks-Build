document.getElementById('codeCloseBtn').addEventListener('click', () => codeOverlay.classList.add('hidden'));
document.getElementById('codeDoneBtn').addEventListener('click', () => codeOverlay.classList.add('hidden'));
codeOverlay.addEventListener('click', (e) => { if(e.target === codeOverlay) codeOverlay.classList.add('hidden'); });
codeCopyBtn.addEventListener('click', () => copyText(codeText.textContent, codeCopyBtn));

/* ============================================================
   SETTINGS PANEL
   ============================================================ */
const settingsPanel = document.getElementById('settingsPanel');
document.getElementById('settingsBtn').addEventListener('click', () => {
  settingsPanel.classList.toggle('hidden');
});
document.getElementById('settingsCloseBtn').addEventListener('click', () => settingsPanel.classList.add('hidden'));

const cfgUrl = document.getElementById('cfgUrl');

function loadConfigIntoForm(){
  cfgUrl.value = config.url;
}
loadConfigIntoForm();

document.getElementById('connectBtn').addEventListener('click', async () => {
  config = { url: cfgUrl.value.trim() || config.url };
  saveJSON(CONFIG_KEY, config);
  settingsPanel.classList.add('hidden');
  await fetchLibrary();
});
document.getElementById('resetSourceBtn').addEventListener('click', async () => {
  if(!confirm('Reset the GitHub source settings back to the default library URL?')) return;
  localStorage.removeItem(CONFIG_KEY);
  config = Object.assign({}, DEFAULT_CONFIG);
  loadConfigIntoForm();
  await fetchLibrary();
});
document.getElementById('reloadBtn').addEventListener('click', fetchLibrary);

/* ============================================================
   INIT
   ============================================================ */
(async function init(){
  if(config.url){
    await fetchLibrary();
  } else {
    settingsPanel.classList.remove('hidden');
  }
})();
</script>
</body>
</html>
