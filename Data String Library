const statusBar = document.getElementById('statusBar');
const statusText = document.getElementById('statusText');

function setStatus(kind, text){
  statusBar.className = 'status ' + (kind || '');
  statusText.innerHTML = text;
}

function parseLibraryText(text){
  text = text.trim();
  // strip byte-order marks etc
  const start = text.indexOf('[');
  const end = text.lastIndexOf(']');
  if(start === -1 || end === -1 || end < start){
    throw new Error('Could not find a [ ... ] array in the file.');
  }
  const arrayText = text.slice(start, end + 1);
  try{
    return JSON.parse(arrayText);
  }catch(e){ /* fall through to JS eval */ }
  try{
    const fn = new Function('"use strict"; return (' + arrayText + ');');
    return fn();
  }catch(e2){
    throw new Error('Found an array but could not parse it: ' + e2.message);
  }
}

async function fetchLibrary(){
  const urls = deriveUrls(config.url);
  if(!urls){
    setStatus('err', `That doesn't look like a GitHub file URL. Use a page like <b>https://github.com/owner/repo/blob/main/path</b>.`);
    return false;
  }

  setStatus('loading', `Loading <b>${escapeHtml(urls.path)}</b> from <b>${escapeHtml(urls.owner)}/${escapeHtml(urls.repo)}</b> (${escapeHtml(urls.branch)})…`);
  let text = null;
  let lastErr = null;

  // 1. try raw.githubusercontent.com (derived from the blob URL)
  try{
    const res = await fetch(urls.rawUrl, { cache: 'no-store' });
    if(res.ok){ text = await res.text(); }
    else lastErr = new Error(`raw file request failed (${res.status})`);
  }catch(e){ lastErr = e; }

  // 2. fall back to the GitHub contents API (base64)
  if(text === null){
    try{
      const res = await fetch(urls.apiUrl, { cache: 'no-store' });
      if(res.ok){
        const json = await res.json();
        if(json.content){
          text = decodeURIComponent(escape(atob(json.content.replace(/\n/g,''))));
        } else {
          lastErr = new Error('API response had no file content.');
        }
      } else {
        lastErr = new Error(`GitHub API request failed (${res.status})`);
      }
    }catch(e){ lastErr = e; }
  }

  if(text === null){
    setStatus('err', `Couldn't load the library. ${escapeHtml(lastErr ? lastErr.message : 'Unknown error')} — check the Library URL in Source settings.`);
    return false;
  }

  let parsed;
  try{
    parsed = parseLibraryText(text);
    if(!Array.isArray(parsed)) throw new Error('File did not contain an array.');
  }catch(e){
    setStatus('err', `Loaded the file but couldn't parse it: ${escapeHtml(e.message)}`);
    return false;
  }

  entries = parsed.map(e => normalizeEntry(e, 'base'));
  nextLocalId = entries.reduce((m, e) => Math.max(m, Number(e.id) || 0), 0) + 1;
  setStatus('ok', `Loaded <b>${entries.length}</b> image${entries.length===1?'':'s'} from GitHub.`);
  refreshFilterOptions();
  applyFiltersAndRender();
  return true;
}

function normalizeEntry(e, status){
  return {
    id: e.id,
    name: e.name || 'Untitled',
    size: Number(e.size) || 0,
    category: e.category || 'Uncategorized',
    author: e.author || '',
    data: e.data || '',
    _status: status,
    _deleted: false
  };
}

function escapeHtml(s){
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}

