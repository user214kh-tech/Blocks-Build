/* ============================================================
   DECODING — reverse of:
   for (y = GRID-1; y >= 0; y--) for (x = 0; x < GRID; x++) stream += grid[y][x]
   ============================================================ */
function decodeDataString(dataStr, size){
  const total = size * size;
  const imageData = new ImageData(Math.max(size,1), Math.max(size,1));
  let unknown = 0;
  let idx = 0;
  for(let y = size - 1; y >= 0; y--){
    for(let x = 0; x < size; x++){
      const ch = idx < dataStr.length ? dataStr[idx] : undefined;
      idx++;
      let rgb = UNKNOWN_RGB;
      if(ch !== undefined && CHAR_MAP.has(ch)){
        rgb = CHAR_MAP.get(ch);
      } else {
        unknown++;
      }
      const p = (y * size + x) * 4;
      imageData.data[p] = rgb[0];
      imageData.data[p+1] = rgb[1];
      imageData.data[p+2] = rgb[2];
      imageData.data[p+3] = 255;
    }
  }
  return { imageData, unknown, expectedLength: total, actualLength: dataStr.length };
}

function renderToCanvas(canvas, dataStr, size){
  size = Math.max(1, size|0);
  canvas.width = size;
  canvas.height = size;
  const ctx = canvas.getContext('2d');
  ctx.imageSmoothingEnabled = false;
  if(!dataStr){ ctx.clearRect(0,0,size,size); return {unknown:0, expectedLength:size*size, actualLength:0}; }
  const { imageData, unknown, expectedLength, actualLength } = decodeDataString(dataStr, size);
  ctx.putImageData(imageData, 0, 0);
  return { unknown, expectedLength, actualLength };
}

