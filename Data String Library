function refreshFilterOptions(){
  const cats = [...new Set(entries.filter(e=>!e._deleted).map(e => e.category))].sort((a,b)=>a.localeCompare(b));
  const sizes = [...new Set(entries.filter(e=>!e._deleted).map(e => e.size))].sort((a,b)=>a-b);

  const curCat = categorySelect.value;
  categorySelect.innerHTML = '<option value="">All categories</option>' +
    cats.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('');
  if(cats.includes(curCat)) categorySelect.value = curCat;

  const curSize = sizeSelect.value;
  sizeSelect.innerHTML = '<option value="">All sizes</option>' +
    sizes.map(s => `<option value="${s}">${s} × ${s}</option>`).join('');
  if(sizes.map(String).includes(curSize)) sizeSelect.value = curSize;

  document.getElementById('categoryList').innerHTML = cats.map(c => `<option value="${escapeHtml(c)}">`).join('');
}

function currentFiltered(){
  const q = searchInput.value.trim().toLowerCase();
  const cat = categorySelect.value;
  const size = sizeSelect.value;

  return entries.filter(e => {
    if(e._deleted) return false;
    if(favOnly && !favorites.has(String(e.id))) return false;
    if(cat && e.category !== cat) return false;
    if(size && String(e.size) !== size) return false;
    if(q){
      const hay = `${e.name} ${e.category} ${e.author}`.toLowerCase();
      if(!hay.includes(q)) return false;
    }
    return true;
  });
}

function applyFiltersAndRender(){
  const list = currentFiltered();
  resultCount.textContent = `${list.length} of ${entries.filter(e=>!e._deleted).length} shown`;
  gridEl.innerHTML = '';
  emptyLibEl.classList.toggle('hidden', list.length > 0);
  list.forEach(entry => gridEl.appendChild(buildCard(entry)));
}

function buildCard(entry){
  const card = document.createElement('div');
  card.className = 'card';

  const thumbWrap = document.createElement('div');
  thumbWrap.className = 'thumbWrap';

  if(entry._status === 'new'){
    const b = document.createElement('div'); b.className = 'badge new'; b.textContent = 'new'; thumbWrap.appendChild(b);
  } else if(entry._status === 'edited'){
    const b = document.createElement('div'); b.className = 'badge edited'; b.textContent = 'edited'; thumbWrap.appendChild(b);
  }

  const favBtn = document.createElement('div');
  favBtn.className = 'favBtn' + (favorites.has(String(entry.id)) ? ' active' : '');
  favBtn.textContent = '♥';
  favBtn.title = 'Toggle favorite';
  favBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const key = String(entry.id);
    if(favorites.has(key)) favorites.delete(key); else favorites.add(key);
    saveJSON(FAV_KEY, [...favorites]);
    favBtn.classList.toggle('active');
    if(favOnly) applyFiltersAndRender();
  });

  const canvas = document.createElement('canvas');
  const meta = renderToCanvas(canvas, entry.data, entry.size);

  thumbWrap.appendChild(canvas);
  thumbWrap.appendChild(favBtn);
  thumbWrap.addEventListener('click', () => openViewModal(entry));

  const metaEl = document.createElement('div');
  metaEl.className = 'meta';
  metaEl.innerHTML = `
    <div class="name">${escapeHtml(entry.name)}</div>
    <div class="sub">
      <span>${entry.size}×${entry.size}</span>
      <span>${escapeHtml(entry.category)}</span>
      ${entry.author ? `<span>by ${escapeHtml(entry.author)}</span>` : ''}
    </div>
  `;
  if(meta.actualLength !== meta.expectedLength || meta.unknown > 0){
    const warn = document.createElement('div');
    warn.className = 'warnLine';
    const parts = [];
    if(meta.actualLength !== meta.expectedLength) parts.push(`length ${meta.actualLength}/${meta.expectedLength}`);
    if(meta.unknown > 0) parts.push(`${meta.unknown} unknown char${meta.unknown===1?'':'s'}`);
    warn.textContent = '⚠ ' + parts.join(' · ');
    metaEl.appendChild(warn);
  }

  const actions = document.createElement('div');
  actions.className = 'cardActions';

  const copyBtn = document.createElement('button');
  copyBtn.className = 'small';
  copyBtn.textContent = 'Copy Data';
  copyBtn.addEventListener('click', () => copyText(entry.data, copyBtn));

  const editBtn = document.createElement('button');
  editBtn.className = 'small';
  editBtn.textContent = 'Edit';
  editBtn.addEventListener('click', () => openFormModal(entry));

  const delBtn = document.createElement('button');
  delBtn.className = 'small danger';
  delBtn.textContent = 'Delete';
  delBtn.addEventListener('click', () => {
    if(!confirm(`Remove "${entry.name}" from the library view? This won't touch GitHub until you export.`)) return;
    entry._deleted = true;
    applyFiltersAndRender();
  });

  actions.append(copyBtn, editBtn, delBtn);
  card.append(thumbWrap, metaEl, actions);
  return card;
}

function copyText(text, btn){
  const done = () => {
    if(!btn) return;
    const old = btn.textContent;
    btn.textContent = 'Copied ✓';
    setTimeout(() => btn.textContent = old, 1200);
  };
  if(navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(text).then(done).catch(() => fallbackCopy(text, done));
  } else {
    fallbackCopy(text, done);
  }
}
function fallbackCopy(text, cb){
  const ta = document.createElement('textarea');
  ta.value = text; document.body.appendChild(ta); ta.select();
  try{ document.execCommand('copy'); }catch(e){}
  document.body.removeChild(ta);
  if(cb) cb();
}

