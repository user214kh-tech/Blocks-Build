/* Turns a github.com "blob" page URL (or an already-raw URL) into the
   raw.githubusercontent.com URL, plus a GitHub API contents URL as a fallback. */
function deriveUrls(sourceUrl){
  const url = (sourceUrl || '').trim();
  let owner, repo, branch, path;

  let m = url.match(/^https:\/\/github\.com\/([^\/]+)\/([^\/]+)\/blob\/([^\/]+)\/(.+)$/);
  if(m){
    [, owner, repo, branch, path] = m;
  } else {
    m = url.match(/^https:\/\/raw\.githubusercontent\.com\/([^\/]+)\/([^\/]+)\/([^\/]+)\/(.+)$/);
    if(m) [, owner, repo, branch, path] = m;
  }
  if(!owner) return null;

  const decodedPath = decodeURIComponent(path);
  const encPath = decodedPath.split('/').map(encodeURIComponent).join('/');

  return {
    owner, repo, branch,
    path: decodedPath,
    rawUrl: `https://raw.githubusercontent.com/${owner}/${repo}/${branch}/${encPath}`,
    apiUrl: `https://api.github.com/repos/${owner}/${repo}/contents/${encPath}?ref=${encodeURIComponent(branch)}`
  };
}

