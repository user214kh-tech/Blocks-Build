<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>75×75 Matrix Character Converter</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#111114;
    --panel:#191a1f;
    --line:#2a2b32;
    --ink:#eae7e0;
    --dim:#8b8c94;
    --accent:#3ddc97;
    --accent-dim:#2a9c6d;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--bg);
    color:var(--ink);
    font-family:'JetBrains Mono', monospace;
    min-height:100vh;
    padding:16px 16px 60px;
  }
  .wrap{max-width:920px;margin:0 auto;}
  header{margin-bottom:22px;}
  h1{
    font-family:'Press Start 2P', monospace;
    font-size:14px;
    line-height:1.6;
    letter-spacing:0.5px;
    margin:0 0 10px;
    color:var(--ink);
  }
  h1 span{color:var(--accent);}
  header p{margin:0;color:var(--dim);font-size:12px;max-width:56ch;}

  .layout{
    display:grid;
    grid-template-columns: 1fr;
    gap:18px;
  }
  @media(min-width:760px){
    .layout{grid-template-columns: 300px 1fr;}
  }

  .panel{
    background:var(--panel);
    border:1px solid var(--line);
    border-radius:2px;
    padding:16px;
  }
  .panel + .panel{margin-top:16px;}

  .drop{
    border:1px dashed var(--line);
    border-radius:2px;
    padding:26px 14px;
    text-align:center;
    cursor:pointer;
    transition:border-color .15s ease, background .15s ease;
  }
  .drop:hover, .drop.drag{
    border-color:var(--accent);
    background:#151920;
  }
  .drop input{display:none;}
  .drop .icon{font-size:22px;color:var(--accent);margin-bottom:8px;}
  .drop .txt{font-size:12.5px;color:var(--dim);}
  .drop .txt b{color:var(--ink);}

  .field{margin-top:16px;}
  .field label{
    display:flex;justify-content:space-between;
    font-size:11px;color:var(--dim);margin-bottom:6px;
    text-transform:uppercase;letter-spacing:0.06em;
  }
  .field label span.val{color:var(--accent);}
  select{
    width:100%;background:#101115;color:var(--ink);
    border:1px solid var(--line);padding:7px 8px;
    font-family:inherit;font-size:12.5px;border-radius:2px;
  }

  button{
    font-family:inherit;
    font-size:12px;
    letter-spacing:0.03em;
    padding:10px 14px;
    border-radius:2px;
    border:1px solid var(--line);
    background:#101115;
    color:var(--ink);
    cursor:pointer;
    transition:border-color .15s ease, color .15s ease;
  }
  button:hover:not(:disabled){border-color:var(--accent);color:var(--accent);}
  button:disabled{opacity:0.35;cursor:not-allowed;}
  
  button.primary{
    background:var(--accent);
    border-color:var(--accent);
    color:#0b1410;
    font-weight:700;
    width: 100%;
    margin-bottom: 10px;
  }
  button.primary:hover:not(:disabled){color:#0b1410;border-color:var(--accent-dim);background:var(--accent-dim);}

  .stage{
    display:flex;flex-direction:column;align-items:center;
    gap:14px;
  }
  .canvases{
    display:flex;gap:22px;flex-wrap:wrap;justify-content:center;align-items:flex-start;
  }
  .canvasblock{text-align:center;}
  .canvasblock .cap{
    font-size:10.5px;color:var(--dim);text-transform:uppercase;
    letter-spacing:0.08em;margin-bottom:8px;
  }
  canvas{
    image-rendering:pixelated;
    border:1px solid var(--line);
    background:#000;
    max-width:100%;
  }
  #srcCanvas{width:120px;height:120px;}
  #outCanvas{width:220px;height:220px;max-width:60vw;max-height:60vw;}

  .empty{
    color:var(--dim);font-size:12.5px;text-align:center;
    padding:60px 20px;
  }

  .palette{
    display:grid;grid-template-columns:repeat(6,1fr);gap:6px;margin-top:8px;
  }
  .swatch{
    aspect-ratio:1;border-radius:2px;border:1px solid rgba(255,255,255,0.08);
    position:relative;cursor:default;
    transition:opacity .12s ease, box-shadow .12s ease, filter .12s ease;
  }
  /* not present in the uploaded image at all */
  .swatch.unused{
    opacity:0.1;
    cursor:not-allowed;
    filter:grayscale(60%);
  }
  /* present in image, currently selected */
  .swatch.usable{cursor:pointer;}
  .swatch.usable.active{
    box-shadow:0 0 0 2px var(--accent);
  }
  .swatch.usable.active::after{
    content:"✓";
    position:absolute;top:2px;right:3px;
    font-size:9px;font-weight:700;color:#08130e;
    background:var(--accent);
    width:12px;height:12px;line-height:12px;text-align:center;
    border-radius:50%;
  }
  /* present in image, currently deselected */
  .swatch.usable.inactive{
    opacity:0.28;
  }
  .swatch.usable.inactive::after{
    content:"✕";
    position:absolute;top:2px;right:3px;
    font-size:9px;font-weight:700;color:#eae7e0;
    background:#000;
    width:12px;height:12px;line-height:12px;text-align:center;
    border-radius:50%;
  }
  .swatch:hover::before{
    content:attr(data-name);
    position:absolute;bottom:110%;left:50%;transform:translateX(-50%);
    background:#000;color:#fff;font-size:9.5px;padding:3px 6px;
    white-space:nowrap;border-radius:2px;z-index:5;border:1px solid var(--line);
  }
  .palette-hint{
    font-size:10.5px;color:var(--dim);margin-top:10px;line-height:1.5;
  }

  .log{
    margin-top:14px;
    width: 100%;
  }
  .log textarea{
    width:100%;height:120px;resize:vertical;
    background:#101115;color:var(--accent);border:1px solid var(--line);
    border-radius:2px;padding:8px;font-family:'JetBrains Mono', monospace;font-size:10px;line-height:1.4;
    word-break: break-all;
  }
  .log .cap{font-size:11px;color:var(--dim);margin-bottom:8px;text-transform:uppercase;letter-spacing:0.06em;}
  .log .cap b{color:var(--ink);}

  footer{margin-top:24px;color:var(--dim);font-size:11px;text-align:center;}
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1><span id="titleSize">75×75</span> <span>MATRIX</span> CONVERTER</h1>
    <p>Converts your image into a perfect grid and exports the data into clean alphabet character keys.</p>
  </header>

  <div class="layout">
    <div class="col-left">
      <div class="panel">
        <div class="drop" id="drop">
          <div class="icon">&#9635;</div>
          <div class="txt"><b>Click to upload</b><br>or drag an image here</div>
          <input type="file" id="fileInput" accept="image/*">
        </div>

        <div class="field">
          <label>Dithering <span class="val" id="ditherLabel">On</span></label>
          <select id="ditherSelect">
            <option value="on">Floyd–Steinberg (on)</option>
            <option value="off">Nearest color only (off)</option>
          </select>
        </div>

        <div class="field">
          <label>Grid size <span class="val" id="gridLabel">75 × 75</span></label>
          <select id="gridSelect">
            <option value="25">25 × 25</option>
            <option value="50">50 × 50</option>
            <option value="75" selected>75 × 75</option>
            <option value="100">100 × 100</option>
            <option value="125">125 × 125</option>
            <option value="150">150 × 150</option>
            <option value="200">200 × 200</option>
            <option value="250">250 × 250</option>
            <option value="300">300 × 300</option>
          </select>
        </div>
      </div>

      <div class="panel">
        <div class="cap" style="font-size:11px;color:var(--dim);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;">36-Color Palette</div>
        <div class="palette" id="palette"></div>
        <div class="palette-hint">Colors found in your image light up and can be toggled off. Colors your image doesn't use stay dim and locked.</div>
      </div>
    </div>

    <div class="col-right">
      <div class="panel stage">
        <div id="emptyState" class="empty">No image yet — upload one to see it converted here.</div>
        <div class="canvases" id="canvasArea" style="display:none;">
          <div class="canvasblock">
            <div class="cap"><span id="srcCap">Source (75×75)</span></div>
            <canvas id="srcCanvas" width="75" height="75"></canvas>
          </div>
          <div class="canvasblock">
            <div class="cap">Processed Result</div>
            <canvas id="outCanvas" width="75" height="75"></canvas>
          </div>
        </div>

        <div class="log" id="logArea" style="display:none;width:100%;">
          <div class="cap"><b>Alphabet Data String Output</b></div>
          <button class="primary" id="copyCodeBtn" disabled>Copy Data String</button>
          <textarea id="logText" readonly></textarea>
        </div>
      </div>
    </div>
  </div>

  <footer>All processing happens locally in your browser.</footer>
</div>

<script>
// ==========================================
// 🎨 CORRECTED 36 GAME PALETTE DEFINITIONS (FIXED SMOKY GREY)
// ==========================================
const PALETTE = [
  ["White",            [255,255,255], "A"], ["Grey",             [99,95,98],    "B"], ["Smoky Grey",        [70,96,117],   "C"],
  ["Black",            [0,0,0],       "D"], ["Red",              [196,40,28],     "E"], ["Dark Red",          [117,0,0],     "F"],
  ["Reddish Orange",   [217,133,108], "G"], ["Orange",           [218,133,65],    "H"], ["Dark Orange",       [139,84,41],   "I"],
  ["Yellowish Orange", [226,155,64],  "J"], ["Yellow",           [245,205,48],    "K"], ["Yellowish Green",   [145,212,84], "L"],
  ["Light Green",      [43,255,111],  "M"], ["Lime Green",       [35,244,46],     "N"], ["Bright Green",      [203,255,154], "O"],
  ["Green",            [75,151,75],   "P"], ["Dark Green",       [0,97,0],        "Q"], ["Forest Green",      [51,104,6],   "R"],
  ["Blueish Green",    [0,143,156],   "S"], ["Teal",             [61,255,208],    "T"], ["Cyan",              [61,171,238],  "U"],
  ["Sky Blue",         [61,171,238],  "V"], ["Blue",             [174,255,254],   "W"], ["Dark Blue",         [0,32,96],     "X"],
  ["Blueish Purple",   [67,84,147],   "Y"], ["Purple",           [107,50,124],    "Z"], ["Dark Purple",       [61,21,133],   "a"],
  ["Pink",             [255,102,204], "b"], ["Bright Pink",      [254,119,254],   "c"], ["Hot Pink",          [250,0,173],   "d"],
  ["Dark Pink",        [235,1,96],    "e"], ["Reddish Purple",   [229,173,200],   "f"], ["Peach",             [249,190,156], "g"],
  ["Light Brown",      [204,153,0],   "h"], ["Brown",            [153,102,0],     "i"], ["Dark Brown",        [102,51,0],    "j"]
];

let GRID = 75;
let lastResult = null;
let rawBuf = null;          // Float32Array of the cropped/resized source pixels, untouched
let usedSet = new Set();    // palette indices actually present in this image (full 36-color pass)
let activeSet = new Set();  // subset of usedSet the user currently has selected

const paletteEl = document.getElementById('palette');
const swatchEls = [];
PALETTE.forEach(([name, rgb], i) => {
  const d = document.createElement('div');
  d.className = 'swatch unused';
  d.style.background = `rgb(${rgb[0]},${rgb[1]},${rgb[2]})`;
  d.dataset.name = name;
  d.addEventListener('click', () => toggleColor(i));
  paletteEl.appendChild(d);
  swatchEls.push(d);
});

function toggleColor(i){
  if(!usedSet.has(i)) return; // locked, not present in the image
  if(activeSet.has(i)){
    if(activeSet.size === 1) return; // keep at least one color active
    activeSet.delete(i);
  } else {
    activeSet.add(i);
  }
  refreshSwatchStates();
  if(rawBuf) recompute();
}

function refreshSwatchStates(){
  swatchEls.forEach((el, i) => {
    el.classList.remove('unused','usable','active','inactive');
    if(usedSet.has(i)){
      el.classList.add('usable');
      el.classList.add(activeSet.has(i) ? 'active' : 'inactive');
    } else {
      el.classList.add('unused');
    }
  });
}

function nearestColor(r,g,b,candidateSet){
  let bestI=-1, bestD=Infinity;
  for(let i=0;i<PALETTE.length;i++){
    if(candidateSet && !candidateSet.has(i)) continue;
    const [,p] = PALETTE[i];
    const dr=r-p[0], dg=g-p[1], db=b-p[2];
    const d=dr*dr+dg*dg+db*db;
    if(d<bestD){bestD=d;bestI=i;}
  }
  return bestI;
}

function clamp(v){return v<0?0:v>255?255:v;}

const drop = document.getElementById('drop');
const fileInput = document.getElementById('fileInput');
const emptyState = document.getElementById('emptyState');
const canvasArea = document.getElementById('canvasArea');
const logArea = document.getElementById('logArea');
const srcCanvas = document.getElementById('srcCanvas');
const outCanvas = document.getElementById('outCanvas');
const logText = document.getElementById('logText');
const ditherSelect = document.getElementById('ditherSelect');
const ditherLabel = document.getElementById('ditherLabel');
const gridSelect = document.getElementById('gridSelect');
const gridLabel = document.getElementById('gridLabel');
const titleSize = document.getElementById('titleSize');
const srcCap = document.getElementById('srcCap');
const copyCodeBtn = document.getElementById('copyCodeBtn');

drop.addEventListener('click', () => fileInput.click());
drop.addEventListener('dragover', e => {e.preventDefault(); drop.classList.add('drag');});
drop.addEventListener('dragleave', () => drop.classList.remove('drag'));
drop.addEventListener('drop', e => {
  e.preventDefault(); drop.classList.remove('drag');
  if(e.dataTransfer.files && e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]);
});
fileInput.addEventListener('change', () => {
  if(fileInput.files && fileInput.files[0]) handleFile(fileInput.files[0]);
});
ditherSelect.addEventListener('change', () => {
  ditherLabel.textContent = ditherSelect.value === 'on' ? 'On' : 'Off';
  if(rawBuf) recompute();
});
gridSelect.addEventListener('change', () => {
  const n = gridSelect.value;
  gridLabel.textContent = `${n} × ${n}`;
  titleSize.textContent = `${n}×${n}`;
  srcCap.textContent = `Source (${n}×${n})`;
  if(window.__lastImg) processImage(window.__lastImg);
});

function handleFile(file){
  if(!file.type.startsWith('image/')) return;
  const reader = new FileReader();
  reader.onload = e => {
    const img = new Image();
    img.onload = () => {
      window.__lastImg = img;
      processImage(img);
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function processImage(img){
  emptyState.style.display = 'none';
  canvasArea.style.display = 'flex';
  logArea.style.display = 'block';

  GRID = parseInt(gridSelect.value, 10);
  srcCanvas.width = GRID; srcCanvas.height = GRID;
  outCanvas.width = GRID; outCanvas.height = GRID;

  const side = Math.min(img.width, img.height);
  const sx = (img.width - side)/2;
  const sy = (img.height - side)/2;

  const work = document.createElement('canvas');
  work.width = GRID; work.height = GRID;
  const wctx = work.getContext('2d');
  wctx.imageSmoothingEnabled = true;
  wctx.imageSmoothingQuality = 'high';
  wctx.drawImage(img, sx, sy, side, side, 0, 0, GRID, GRID);

  const sctx = srcCanvas.getContext('2d');
  sctx.clearRect(0,0,GRID,GRID);
  sctx.drawImage(work, 0, 0);

  const imgData = wctx.getImageData(0,0,GRID,GRID);
  const data = imgData.data;

  rawBuf = new Float32Array(GRID*GRID*3);
  for(let i=0;i<GRID*GRID;i++){
    rawBuf[i*3]   = data[i*4];
    rawBuf[i*3+1] = data[i*4+1];
    rawBuf[i*3+2] = data[i*4+2];
  }

  // first pass across the full 36-color palette just to find out which
  // colors this image actually uses
  const allIdx = new Set(PALETTE.map((_, i) => i));
  usedSet = quantize(allIdx, false).usedIndices;
  activeSet = new Set(usedSet);
  refreshSwatchStates();

  recompute();
  copyCodeBtn.disabled = false;
}

// Runs quantization (with optional dithering) over rawBuf restricted to
// candidateSet, returns the per-pixel result grid plus which colors got used.
function quantize(candidateSet, useDither){
  const buf = Float32Array.from(rawBuf);
  const result = [];
  for(let y=0;y<GRID;y++) result.push(new Array(GRID));
  const usedIndices = new Set();

  for(let y=0;y<GRID;y++){
    for(let x=0;x<GRID;x++){
      const i = y*GRID+x;
      const r = buf[i*3], g = buf[i*3+1], b = buf[i*3+2];
      const idx = nearestColor(r,g,b,candidateSet);
      const [name, prgb, char] = PALETTE[idx];
      result[y][x] = {char, rgb: prgb, idx};
      usedIndices.add(idx);

      if(useDither){
        const er = r - prgb[0];
        const eg = g - prgb[1];
        const eb = b - prgb[2];

        const spread = (xx,yy,f) => {
          if(xx>=0 && xx<GRID && yy>=0 && yy<GRID){
            const j=(yy*GRID+xx)*3;
            buf[j]   = clamp(buf[j]   + er*f);
            buf[j+1] = clamp(buf[j+1] + eg*f);
            buf[j+2] = clamp(buf[j+2] + eb*f);
          }
        };
        spread(x+1,y,   7/16);
        spread(x-1,y+1, 3/16);
        spread(x,  y+1, 5/16);
        spread(x+1,y+1, 1/16);
      }
    }
  }
  return {result, usedIndices};
}

function recompute(){
  if(!rawBuf) return;
  const useDither = ditherSelect.value === 'on';
  const {result} = quantize(activeSet, useDither);
  lastResult = result;

  const octx = outCanvas.getContext('2d');
  const outData = octx.createImageData(GRID, GRID);
  for(let y=0;y<GRID;y++){
    for(let x=0;x<GRID;x++){
      const {rgb} = result[y][x];
      const i = (y*GRID+x)*4;
      outData.data[i]=rgb[0]; outData.data[i+1]=rgb[1]; outData.data[i+2]=rgb[2]; outData.data[i+3]=255;
    }
  }
  octx.putImageData(outData, 0, 0);

  buildLog();
}

function buildLog(){
  let singleStream = "";
  for(let y = GRID - 1; y >= 0; y--){
    for(let x = 0; x < GRID; x++){
      singleStream += lastResult[y][x].char;
    }
  }
  logText.value = singleStream;
}

copyCodeBtn.addEventListener('click', () => {
  logText.select();
  document.execCommand('copy');
  const oldText = copyCodeBtn.textContent;
  copyCodeBtn.textContent = 'Copied!';
  setTimeout(() => { copyCodeBtn.textContent = oldText; }, 1500);
});
</script>
</body>
</html>
