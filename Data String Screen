-- High-Res Preview Visual Drawing
local function RenderSelectedArt()
	local expectedTotal = libraryCanvasSize * libraryCanvasSize
	PreviewGridLayout.CellSize = UDim2.new(1 / libraryCanvasSize, 0, 1 / libraryCanvasSize, 0)
	
	if #previewCache < expectedTotal then
		local currentCount = #previewCache
		local needed = expectedTotal - currentCount
		for i = 1, needed do
			local nextIdx = currentCount + i
			local Pixel = Instance.new("Frame")
			Pixel.BorderSizePixel = 0
			Pixel.LayoutOrder = nextIdx
			Pixel.Parent = LibraryPreview
			previewCache[nextIdx] = Pixel
			if i % 3000 == 0 then task.wait() end
		end
	end
	
	local dataLen = string.len(libraryDataString)
	for i = 1, #previewCache do
		local pixelFrame = previewCache[i]
		if i <= expectedTotal then
			pixelFrame.Visible = true
			if i <= dataLen then
				local char = string.sub(libraryDataString, i, i)
				pixelFrame.BackgroundColor3 = COLOR_RGB_MAP[char] or Color3.fromRGB(15, 15, 15)
			else
				pixelFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
			end
		else
			pixelFrame.Visible = false
		end
	end
end

-- Fast card dynamic down-sampler
local function PopulateMediaThumbnailCard(parentCard, dataString, targetSize)
	local ThumbCanvas = Instance.new("Frame")
	ThumbCanvas.Size = UDim2.new(1, 0, 1, -22)
	ThumbCanvas.BackgroundTransparency = 1
	ThumbCanvas.ClipsDescendants = true
	ThumbCanvas.Parent = parentCard

	local Grid = Instance.new("UIGridLayout")
	Grid.CellPadding = UDim2.new(0, 0, 0, 0)
	Grid.StartCorner = Enum.StartCorner.BottomLeft
	Grid.CellSize = UDim2.new(1 / 25, 0, 1 / 25, 0)
	Grid.Parent = ThumbCanvas

	for y = 1, 25 do
		local sourceY = math.clamp(math.round((y / 25) * targetSize), 1, targetSize)
		for x = 1, 25 do
			local sourceX = math.clamp(math.round((x / 25) * targetSize), 1, targetSize)
			local dataIndex = (sourceY - 1) * targetSize + sourceX
			
			local char = string.sub(dataString, dataIndex, dataIndex)
			local color = COLOR_RGB_MAP[char] or Color3.fromRGB(20, 20, 20)

			local p = Instance.new("Frame")
			p.BorderSizePixel = 0
			p.BackgroundColor3 = color
			p.Parent = ThumbCanvas
		end
	end
end

-- ==========================================================================
-- 🚀 RUNTIME MULTI-CANVAS VERTICAL ENGINE
-- ==========================================================================
local function runWorkspaceMatrixEngine(dataString, cfg, posSetting)
	local GRID_SIZE = cfg.canvas
	local SECTOR_SIZE = cfg.sector
	local STEP = 3
	
	-- Plot Boundary Definitions
	local MIN_X = -646.5
	local MAX_X = 547.5
	local MIN_Z = -547.5
	local MAX_Z = 646.5
	
	local MAP_CENTER_Z = (MIN_Z + MAX_Z) / 2
	local singlePadding = STEP -- 1 block padding (3 studs)
	
	-- Location routing adjusts baseline X and Z coordinates exclusively
	local CENTER_X, CENTER_Z
	local placementCFrame = CFrame.new(0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 0, 1)
	local isFront = (posSetting == "Front")
	
	if posSetting == "Middle" then
		CENTER_X = -49.5
		CENTER_Z = 49.5
		placementCFrame = CFrame.new(0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 0, 1)
	elseif posSetting == "Front" then
		CENTER_X = MAX_X - singlePadding
		CENTER_Z = MAP_CENTER_Z
		placementCFrame = CFrame.Angles(0, math.rad(180), 0)
	elseif posSetting == "Back" then
		CENTER_X = MIN_X + singlePadding
		CENTER_Z = MAP_CENTER_Z
		placementCFrame = CFrame.Angles(0, 0, 0)
	end
	
	-- Compute original vertical engine coordinate starts
	local START_X = CENTER_X
	local START_Y = 1.5        
	local START_Z = CENTER_Z - (((GRID_SIZE - 1) / 2) * STEP)
	
	-- 1. Parse string array seamlessly matching runtime coordinates
	local imageMatrix = {}
	for row = 1, GRID_SIZE do
		imageMatrix[row] = {}
		for col = 1, GRID_SIZE do
			local stringIndex = ((row - 1) * GRID_SIZE) + col
			local characterKey = string.sub(dataString, stringIndex, stringIndex)
			imageMatrix[row][col] = COLOR_NAME_MAP[characterKey] or "White"
		end
	end
	
	-- 2. Dynamically prepare active workspace clusters
	local sectorsPerSide = math.ceil(GRID_SIZE / SECTOR_SIZE)
	local sectors = {}
	for sRow = 0, sectorsPerSide - 1 do
		for sCol = 0, sectorsPerSide - 1 do
			table.insert(sectors, {
				rowStart = (sRow * SECTOR_SIZE) + 1,
				rowEnd = math.min((sRow + 1) * SECTOR_SIZE, GRID_SIZE),
				colStart = (sCol * SECTOR_SIZE) + 1,
				colEnd = math.min((sCol + 1) * SECTOR_SIZE, GRID_SIZE)
			})
		end
	end
	
	local spawnCounter = 0
	local THROTTLE_LIMIT = 14 -- Optimized placements per frame
	
	-- 3. Sequentially step coordinates sector by sector (1 to total sectors)
	for index, sector in ipairs(sectors) do
		StatusValue.Text = "Painting (" .. index .. "/" .. #sectors .. ")"
		StatusValue.TextColor3 = Color3.fromRGB(235, 180, 60)
		
		local actualSectorRows = (sector.rowEnd - sector.rowStart) + 1
		local actualSectorCols = (sector.colEnd - sector.colStart) + 1
		local centerRow = sector.rowStart + math.floor(actualSectorRows / 2)
		local centerCol = sector.colStart + math.floor(actualSectorCols / 2)
		
		local sectorCenterY = START_Y + ((centerRow - 1) * STEP)
		local centerColOffset = isFront and (centerCol - 1) or (GRID_SIZE - centerCol)
		local sectorCenterZ = START_Z + (centerColOffset * STEP)
		
		-- Subtracted 4 instead of adding 4 if it's the "Front" layout to keep you on the grass side
		local xTeleportOffset = isFront and -4 or 4
		local lookAngle = isFront and math.rad(-90) or math.rad(90)
		
		HumanoidRootPart.CFrame = CFrame.new(START_X + xTeleportOffset, sectorCenterY, sectorCenterZ) * CFrame.Angles(0, lookAngle, 0)
		task.wait(0.12)
		
		-- Loop over sorted layout palette inside workspace cluster
		for _, targetColor in ipairs(paletteColors) do
			local colorHasBeenEquipped = false
			
			for row = sector.rowStart, sector.rowEnd do
				local currentY = START_Y + ((row - 1) * STEP)
				
				for col = sector.colStart, sector.colEnd do
					if imageMatrix[row][col] == targetColor then
						local colOffset = isFront and (col - 1) or (GRID_SIZE - col)
						local currentZ = START_Z + (colOffset * STEP)
						
						if not colorHasBeenEquipped then
							InventoryRF:InvokeServer("Equip", "SelectedColor", targetColor)
							task.wait(0.02)
							colorHasBeenEquipped = true
						end
						
						task.spawn(function()
							pcall(function()
								PlaceBuildRF:InvokeServer(
									targetColor,
									START_X,
									currentY,
									currentZ,
									placementCFrame,
									1,
									1
								)
							end)
						end)
						
						spawnCounter = spawnCounter + 1
						if spawnCounter >= THROTTLE_LIMIT then
							spawnCounter = 0
							task.wait()
						end
					end
				end
			end
			task.wait(0.01)
		end
	end
	
	StatusValue.Text = "Ready"
	StatusValue.TextColor3 = Color3.fromRGB(61, 220, 151)
	MainFrame.Visible = true
end

