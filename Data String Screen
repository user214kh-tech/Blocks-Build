-- 🌐 GITHUB LOADER PIPELINE
-- ==========================================================================
local function DownloadGitHubLibrary()
	local url = "https://raw.githubusercontent.com/user214kh-tech/Blocks-Build/main/Data%20String%20Library"
	local success, response = pcall(function() return game:HttpGet(url) end)
	
	if not success then return end
	
	local sanitizedResponse = response:gsub("([%w_]+)%s*:", '"%1":')
	local decodeSuccess, dataArray = pcall(function() return HttpService:JSONDecode(sanitizedResponse) end)
	
	if not decodeSuccess then return end
	
	for _, item in ipairs(dataArray) do
		if item.name and item.data then
			-- Create visual Netflix cover tile card
			local CardButton = Instance.new("TextButton")
			CardButton.Text = ""
			CardButton.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
			CardButton.BorderSizePixel = 0
			CardButton.Parent = StreamScroll

			local CardCorner = Instance.new("UICorner")
			CardCorner.CornerRadius = UDim.new(0, 4)
			CardCorner.Parent = CardButton

			-- Info label card overlay
			local TextLabel = Instance.new("TextLabel")
			TextLabel.Size = UDim2.new(1, 0, 0, 22)
			TextLabel.Position = UDim2.new(0, 0, 1, -22)
			TextLabel.BackgroundColor3 = Color3.fromRGB(38, 38, 43)
			TextLabel.Text = "  " .. tostring(item.name)
			TextLabel.TextColor3 = Color3.fromRGB(230, 230, 230)
			TextLabel.TextSize = 10
			TextLabel.Font = Enum.Font.SourceSansBold
			TextLabel.TextXAlignment = Enum.TextXAlignment.Left
			TextLabel.Parent = CardButton
			
			-- Render visual down-sampled thumbnail
			task.spawn(PopulateMediaThumbnailCard, CardButton, item.data, tonumber(item.size) or 75)
			
			-- Handle card selected
			CardButton.MouseButton1Click:Connect(function()
				libraryCanvasSize = tonumber(item.size) or 75
				libraryDataString = item.data
				task.spawn(RenderSelectedArt)
			end)
		end
	end
end

task.spawn(DownloadGitHubLibrary)

