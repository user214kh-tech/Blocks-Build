-- LIBRARY EXECUTE TRIGGER
ExecuteBuildBtn.MouseButton1Click:Connect(function()
	if libraryDataString == "" then
		ExecuteBuildBtn.Text = "SELECT AN ARTWORK THUMBNAIL FIRST"
		task.wait(1.5)
		ExecuteBuildBtn.Text = "EXECUTE BUILD"
		return
	end

	-- Find config layout matching the library item size
	local currentConfig = nil
	for _, config in ipairs(SIZES_CONFIG) do
		if config.canvas == libraryCanvasSize then
			currentConfig = config
			break
		end
	end

	-- Fallback if exact matching config isn't found
	if not currentConfig then
		currentConfig = {name = libraryCanvasSize.."x"..libraryCanvasSize, canvas = libraryCanvasSize, sector = 27}
	end

	MainFrame.Visible = false
	runWorkspaceMatrixEngine(libraryDataString, currentConfig, selectedPosition)
end)

